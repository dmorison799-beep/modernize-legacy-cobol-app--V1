# Node.js Accounting App - Environment Configuration
# Copy this file to .env and adjust values as needed

# Application settings
NODE_ENV=production
APP_PORT=3000
INITIAL_BALANCE=1000.00
HEALTH_PORT=3000

# AWS Deployment (for deploy-aws command)
AWS_REGION=us-east-1
ECR_REPO=node-accounting-app
ECS_CLUSTER=node-accounting-app-cluster
ECS_SERVICE=node-accounting-app-service

# Azure Deployment (for deploy-azure command)
AZURE_RESOURCE_GROUP=node-accounting-app-rg
AZURE_APP_PLAN=node-accounting-app-plan
AZURE_WEBAPP_NAME=node-accounting-app
AZURE_LOCATION=eastus
