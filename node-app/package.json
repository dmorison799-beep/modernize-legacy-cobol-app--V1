{
  "name": "node-accounting-app",
  "version": "1.0.0",
  "description": "Modern Node.js accounting application - migrated from legacy COBOL system",
  "main": "src/main.js",
  "scripts": {
    "start": "node src/main.js",
    "server": "node src/server.js",
    "test": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix"
  },
  "keywords": ["accounting", "cobol-migration", "nodejs"],
  "author": "Modernization Team",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
